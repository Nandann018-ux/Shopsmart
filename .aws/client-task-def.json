{
  "family": "urbangear-client",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::607062993037:role/LabRole",
  "taskRoleArn": "arn:aws:iam::607062993037:role/LabRole",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "urbangear-client",
      "image": "607062993037.dkr.ecr.us-east-1.amazonaws.com/urbangear-client:amd64",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "VITE_API_URL",
          "value": "http://urbangear-alb-163835046.us-east-1.elb.amazonaws.com/api"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/urbangear-client",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
