{
  "family": "urbangear-server",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::607062993037:role/LabRole",
  "taskRoleArn": "arn:aws:iam::607062993037:role/LabRole",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "urbangear-server",
      "image": "607062993037.dkr.ecr.us-east-1.amazonaws.com/urbangear-server:amd64",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5001,
          "hostPort": 5001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "5001"
        },
        {
          "name": "NODE_ENV",
          "value": "production"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/urbangear-server",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
