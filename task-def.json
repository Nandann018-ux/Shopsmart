{
  "family": "urbangear-task",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::607062993037:role/LabRole",
  "taskRoleArn": "arn:aws:iam::607062993037:role/LabRole",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "urbangear-container",
      "image": "607062993037.dkr.ecr.us-east-1.amazonaws.com/urbangear:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ]
    }
  ]
}
